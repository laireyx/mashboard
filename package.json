{
  "name": "mashboard",
  "version": "0.1.0",
  "description": "A Vite, React, and Electron desktop app.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b --noEmit && electron-vite build",
    "type": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "electron-vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@vanilla-extract/css": "^1.21.0",
    "koffi": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-react-x": "^5.9.3",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.mashboard.app",
    "productName": "Mashboard",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
